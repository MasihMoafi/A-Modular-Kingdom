+use crate::auth::SharedAuthProvider;
+use crate::endpoint::session::EndpointSession;
+use crate::error::ApiError;
+use crate::provider::Provider;
+use codex_client::HttpTransport;
+use codex_client::RequestTelemetry;
+use http::HeaderMap;
+use http::Method;
+use serde_json::Value;
+use std::sync::Arc;
+use tracing::instrument;
+
+/// Minimal client for providers that expose the OpenAI-compatible Chat Completions endpoint.
+pub struct ChatCompletionsClient<T: HttpTransport> {
+    session: EndpointSession<T>,
+}
+
+impl<T: HttpTransport> ChatCompletionsClient<T> {
+    pub fn new(transport: T, provider: Provider, auth: SharedAuthProvider) -> Self {
+        Self {
+            session: EndpointSession::new(transport, provider, auth),
+        }
+    }
+
+    pub fn with_telemetry(self, request: Option<Arc<dyn RequestTelemetry>>) -> Self {
+        Self {
+            session: self.session.with_request_telemetry(request),
+        }
+    }
+
+    #[instrument(
+        name = "chat_completions.complete",
+        level = "info",
+        skip_all,
+        fields(http.method = "POST", api.path = "chat/completions")
+    )]
+    pub async fn complete(
+        &self,
+        request: Value,
+        extra_headers: HeaderMap,
+    ) -> Result<Value, ApiError> {
+        let response = self
+            .session
+            .execute(
+                Method::POST,
+                "chat/completions",
+                extra_headers,
+                Some(request),
+            )
+            .await?;
+        serde_json::from_slice(&response.body)
+            .map_err(|err| ApiError::Stream(format!("invalid chat completions response: {err}")))
+    }
+}
